<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="warn" xmlns="http://logging.apache.org/log4j/2.0/config">
    <Properties>
        <Property name="APPLICATION_NAME">
            MockServer
        </Property>
        <Property name="TIMESTAMP">
            %d{yyyy-MM-ddTHH:mm:ss}
        </Property>
        <Property name="DATE_STAMP">
            $${date:yyyy-MM}
        </Property>
        <Property name="LOG_PATTERN">
            TimeStamp=${TIMESTAMP} Application=${APPLICATION_NAME} Tracer=%X{tracer} Level=%p Class=%c{1.}::%M Line=%L %m%n
        </Property>
        <Property name="FILE_NAME">
            <!-- Setting month as file naming pattern to reduce number of log files created in user's system -->
            /tmp/${APPLICATION_NAME}/logs/${APPLICATION_NAME} ${DATE_STAMP}.log
        </Property>
    </Properties>
    <Appenders>
        <Console name="console" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="${LOG_PATTERN}"/>
        </Console>
        <File name="log-file" fileName="${FILE_NAME}">
            <PatternLayout
                    pattern="${LOG_PATTERN}"/>
        </File>
    </Appenders>
    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="console"/>
            <AppenderRef ref="log-file"/>
        </Root>
        <Logger name="info-logger" level="INFO">
            <AppenderRef ref="console"/>
            <AppenderRef ref="log-file"/>
        </Logger>
        <Logger name="error-logger" level="ERROR">
            <AppenderRef ref="console"/>
            <AppenderRef ref="log-file"/>
        </Logger>
        <Logger name="warn-logger" level="WARN">
            <AppenderRef ref="console"/>
            <AppenderRef ref="log-file"/>
        </Logger>
    </Loggers>
</Configuration>