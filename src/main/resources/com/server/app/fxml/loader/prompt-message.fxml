<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="292.0"
            prefWidth="458.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.server.app.controller.PromptMessageController">
    <children>
        <VBox nodeOrientation="RIGHT_TO_LEFT" prefHeight="299.0" prefWidth="458.0">
            <children>
                <TextFlow fx:id="messageTextFlow" prefHeight="242.0" prefWidth="448.0"
                          style="-fx-background-color: #ececec; -fx-border-radius: 5; -fx-background-radius: 5;">
                    <VBox.margin>
                        <Insets left="5.0" right="5.0" top="5.0"/>
                    </VBox.margin>
                </TextFlow>
                <Button fx:id="messageAcceptButton" mnemonicParsing="false"
                        style="-fx-background-color: #31ae28; -fx-background-radius: 5; -fx-border-radius: 5;"
                        text="Close" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="12.0"/>
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                    <VBox.margin>
                        <Insets left="5.0" top="10.0"/>
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>
