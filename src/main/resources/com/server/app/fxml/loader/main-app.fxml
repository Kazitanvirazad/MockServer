<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="mainlayout" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.server.app.controller.MainAppController">
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="importCollectionMenuItem" mnemonicParsing="false" text="Import Collections"/>
                        <MenuItem fx:id="exportCollectionMenuItem" mnemonicParsing="false" text="Export Collections"/>
                        <MenuItem fx:id="settingsMenuItem" mnemonicParsing="false" text="Settings"/>
                        <MenuItem fx:id="closeAppMenuItem" mnemonicParsing="false" text="Close"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Options">
                    <items>
                        <MenuItem fx:id="activeServersMenuItem" mnemonicParsing="false" text="Active Servers"/>
                        <MenuItem fx:id="createCollectionMenuItem" mnemonicParsing="false" text="Create Collection"/>
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Donate"/>
                        <MenuItem mnemonicParsing="false" text="MIT License"/>
                        <MenuItem mnemonicParsing="false" text="Source Code"/>
                        <MenuItem mnemonicParsing="false" text="Check for update"/>
                        <MenuItem mnemonicParsing="false" text="About"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <left>
        <AnchorPane prefHeight="675.0" prefWidth="213.0" BorderPane.alignment="CENTER">
            <children>
                <TableView fx:id="collectionTable" editable="true" layoutX="2.0" prefHeight="675.0" prefWidth="228.0"
                           AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <columns>
                        <TableColumn fx:id="collectionNameCol" prefWidth="186.0" resizable="false" sortable="false"
                                     text="Collections"/>
                        <TableColumn fx:id="collectionDeleteCol" editable="false" minWidth="0.0" prefWidth="44.0"
                                     resizable="false" sortable="false">
                            <graphic>
                                <Button mnemonicParsing="false" onAction="#addCollectionEvent" prefHeight="25.0"
                                        prefWidth="54.0" style="-fx-background-color: #31ae28;" text="Add"
                                        textAlignment="CENTER" textFill="WHITE" wrapText="true">
                                    <cursor>
                                        <Cursor fx:constant="HAND"/>
                                    </cursor>
                                </Button>
                            </graphic>
                        </TableColumn>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
            <BorderPane.margin>
                <Insets bottom="5.0" left="5.0" right="2.0"/>
            </BorderPane.margin>
        </AnchorPane>
    </left>
    <center>
        <AnchorPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <children>
                <TableView fx:id="serverTable" layoutX="4.0" layoutY="32.0" prefHeight="639.0" prefWidth="962.0"
                           AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                           AnchorPane.topAnchor="34.0">
                    <columns>
                        <TableColumn fx:id="serverNameCol" prefWidth="176.0" text="Name"/>
                        <TableColumn fx:id="serverUrlCol" prefWidth="285.0" text="URL"/>
                        <TableColumn fx:id="serverMethodCol" minWidth="0.0" prefWidth="74.0" text="Method"/>
                        <TableColumn fx:id="serverStatusCodeCol" prefWidth="91.0" text="Status Code"/>
                        <TableColumn fx:id="serverDelayCol" prefWidth="73.0" text="Delay"/>
                        <TableColumn fx:id="serverPortCol" prefWidth="94.0" text="Port"/>
                        <TableColumn fx:id="serverStatusCol" prefWidth="86.0" resizable="false" text="Status"/>
                        <TableColumn fx:id="serverDeleteCol" prefWidth="76.0" resizable="false" sortable="false">
                            <graphic>
                                <Button mnemonicParsing="false" onAction="#createServerEvent" prefHeight="25.0"
                                        prefWidth="69.0" style="-fx-background-color: #31ae28;" text="Create"
                                        textAlignment="CENTER" textFill="WHITE" wrapText="true">
                                    <cursor>
                                        <Cursor fx:constant="HAND"/>
                                    </cursor>
                                </Button>
                            </graphic>
                        </TableColumn>
                    </columns>
                </TableView>
                <Text fill="#3b3b3b" layoutX="8.0" layoutY="20.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Servers"
                      textAlignment="CENTER" wrappingWidth="71.109375">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </Text>
                <HBox fx:id="activeServerHBox" alignment="CENTER_LEFT" layoutX="605.0" layoutY="1.0" prefHeight="31.0"
                      prefWidth="165.0" AnchorPane.rightAnchor="0.0">
                    <children>
                        <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Active Servers: ">
                            <HBox.margin>
                                <Insets left="10.0"/>
                            </HBox.margin>
                            <font>
                                <Font size="13.0"/>
                            </font>
                        </Text>
                        <Text fx:id="activeServerCountText" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0">
                            <HBox.margin>
                                <Insets left="5.0"/>
                            </HBox.margin>
                            <font>
                                <Font size="13.0"/>
                            </font>
                        </Text>
                    </children>
                </HBox>
            </children>
            <BorderPane.margin>
                <Insets bottom="5.0" left="2.0" right="5.0"/>
            </BorderPane.margin>
        </AnchorPane>
    </center>
    <bottom>
        <AnchorPane prefHeight="32.0" prefWidth="1200.0" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="5.0" left="5.0" right="5.0"/>
            </BorderPane.margin>
            <children>
                <HBox alignment="CENTER_RIGHT" prefHeight="25.0" prefWidth="1219.0" AnchorPane.bottomAnchor="0.0"
                      AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#startServerEvent"
                                style="-fx-background-color: #31ae28;" text="Start Server" textFill="WHITE">
                            <cursor>
                                <Cursor fx:constant="HAND"/>
                            </cursor>
                            <HBox.margin>
                                <Insets right="5.0"/>
                            </HBox.margin>
                            <font>
                                <Font name="System Bold" size="12.0"/>
                            </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#stopServerEvent"
                                style="-fx-background-color: #f44336;" text="Stop Server" textFill="WHITE">
                            <cursor>
                                <Cursor fx:constant="HAND"/>
                            </cursor>
                            <font>
                                <Font name="System Bold" size="12.0"/>
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </AnchorPane>
    </bottom>
</BorderPane>
